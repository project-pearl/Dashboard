# ============================================================
# PIN Dashboard — Environment Variables
# Copy to .env.local and fill in values
# ============================================================

# --- Supabase (required) ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Mapbox (required for maps) ---
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your-mapbox-token

# --- OpenAI (required for AI features) ---
OPENAI_API_KEY=sk-your-openai-key

# --- Cron Authentication ---
CRON_SECRET=your-cron-secret

# --- Invite Tokens ---
INVITE_TOKEN_SECRET=your-invite-hmac-secret

# --- Sentry Error Tracking ---
SENTRY_DSN=https://your-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=your-sentry-project
SENTRY_AUTH_TOKEN=sntrys_your-auth-token

# --- Slack Notifications ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# --- Email (Resend) ---
RESEND_API_KEY=re_your-resend-key
ALERT_FROM_EMAIL=alerts@yourdomain.com
PIN_ALERTS_EMAIL=ops@yourdomain.com
PIN_ALERTS_ENABLED=true
PIN_ALERTS_LOG_ONLY=false

# --- Rate Limiting (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# --- Vercel Blob Storage ---
BLOB_READ_WRITE_TOKEN=vercel_blob_your-token

# --- Data Source API Keys ---
CBIBS_API_KEY=your-cbibs-key
WATER_REPORTER_API_KEY=your-water-reporter-key
AIRNOW_API_KEY=your-airnow-key
CDC_SOCRATA_APP_TOKEN=your-socrata-token
SAM_GOV_API_KEY=your-sam-gov-key
OPENFEC_API_KEY=your-openfec-key
FEC_API_KEY=your-fec-key

# --- Sentinel Configuration ---
SENTINEL_ENABLED=true
SENTINEL_SCORING=true
SENTINEL_LLM=true
SENTINEL_LOG_ONLY=false

# --- Application URLs (auto-set by Vercel, override locally) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_ORIGIN=http://localhost:3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# --- Testing ---
# TEST_FEDERAL_EMAIL=test@example.com
# TEST_FEDERAL_PASSWORD=test-password
